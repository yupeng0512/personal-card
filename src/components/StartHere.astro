---
const routes = [
  {
    label: 'Recruiter',
    title: '快速看候选人主线',
    description: '职业经历、核心方向和可展开的项目证据，适合先判断匹配度。',
    href: '/about',
    action: '查看经历',
  },
  {
    label: 'Engineer',
    title: '看系统设计与项目实现',
    description: '从精选项目进入完整项目矩阵，关注架构、链路、技术栈和可运行性。',
    href: '/projects',
    action: '查看项目',
  },
  {
    label: 'AI Builder',
    title: '看 AI Native 工作流',
    description: '项目级知识库、Review 规则、Skills 和自动化系统如何进入研发流程。',
    href: 'https://github.com/yupeng0512/engineering-playbook',
    action: '查看 Playbook',
    external: true,
  },
];
---

<section class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
  <div class="mb-8">
    <p class="mb-2 text-sm font-semibold text-primary-600 dark:text-primary-400">Start Here</p>
    <h2 class="text-3xl font-bold text-surface-900 dark:text-white">按访问目的进入</h2>
    <p class="mt-3 max-w-2xl text-surface-500 dark:text-surface-400">
      首页只保留最能证明主线的入口，完整项目和学习资产放到二级页面，避免信息堆叠。
    </p>
  </div>

  <div class="grid gap-4 md:grid-cols-3">
    {routes.map(route => (
      <a
        href={route.href}
        target={route.external ? '_blank' : undefined}
        rel={route.external ? 'noopener noreferrer' : undefined}
        class="group flex min-h-48 flex-col justify-between rounded-lg border border-surface-200 bg-white p-6 transition-all duration-300 hover:-translate-y-1 hover:border-primary-300 hover:shadow-lg dark:border-surface-700 dark:bg-surface-900"
      >
        <div>
          <div class="mb-4 inline-flex rounded-full bg-surface-100 px-3 py-1 text-xs font-semibold text-surface-600 dark:bg-surface-800 dark:text-surface-300">
            {route.label}
          </div>
          <h3 class="text-xl font-bold text-surface-900 transition-colors group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400">
            {route.title}
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-surface-500 dark:text-surface-400">{route.description}</p>
        </div>
        <div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-primary-600 dark:text-primary-400">
          {route.action}
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </div>
      </a>
    ))}
  </div>
</section>
