---
import workspaceData from '../data/workspace-data.json';
import { getAllProjects, getFeaturedProjects } from '../lib/projects';

const { stats } = workspaceData;
const totalProjects = getAllProjects().length;
const featuredProjects = getFeaturedProjects().length;
const aiWorkflows = stats.totalAgents + stats.totalSkills;

const statItems = [
  {
    label: '精选证据项目',
    value: featuredProjects,
    detail: `从 ${totalProjects} 个公开项目中收敛主线`,
  },
  {
    label: 'AI 工作流资产',
    value: aiWorkflows,
    detail: 'Skills / Rules / Agents 可复用沉淀',
  },
  {
    label: '工程知识库',
    value: stats.totalExperienceArchives,
    detail: `${stats.totalPatterns} 个 Pattern 与项目复盘`,
  },
  {
    label: '运行中系统',
    value: '3+',
    detail: 'GitHub Sentinel / InfoHunter / AI Video Matrix',
  },
];
---

<section class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {statItems.map(item => (
      <div class="glass rounded-lg p-5 card-hover">
        <div class="text-2xl sm:text-3xl font-bold text-surface-800 dark:text-white">
          {item.value}
        </div>
        <div class="mt-1 text-sm font-semibold text-surface-700 dark:text-surface-200">{item.label}</div>
        <div class="mt-2 text-xs leading-relaxed text-surface-500 dark:text-surface-400">{item.detail}</div>
      </div>
    ))}
  </div>
</section>
