---
import workspaceData from '../data/workspace-data.json';
import { getAllProjects, getFeaturedProjects } from '../lib/projects';

const { stats } = workspaceData;
const totalProjects = getAllProjects().length;
const featuredProjects = getFeaturedProjects().length;
const aiWorkflows = stats.totalAgents + stats.totalSkills;

const statItems = [
  { label: '公开项目', value: totalProjects, icon: '01' },
  { label: '核心项目', value: featuredProjects, icon: '02' },
  { label: 'AI 工作流', value: aiWorkflows, icon: '03' },
  { label: '学习笔记', value: stats.totalNotes, icon: '04' },
  { label: '可复用 Pattern', value: stats.totalPatterns, icon: '05' },
  { label: '经验档案', value: stats.totalExperienceArchives, icon: '06' },
];
---

<section class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
    {statItems.map(item => (
      <div class="glass rounded-lg p-4 text-center card-hover">
        <div class="text-xs font-semibold tracking-widest text-primary-500 dark:text-primary-400 mb-2">{item.icon}</div>
        <div class="text-2xl sm:text-3xl font-bold text-surface-700 dark:text-white">
          {item.value}
        </div>
        <div class="text-xs text-surface-500 dark:text-surface-400 mt-1">{item.label}</div>
      </div>
    ))}
  </div>
</section>
