---
import overrides from '../data/overrides.json';

const { profile } = overrides;
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-[linear-gradient(180deg,rgba(248,249,250,0.96),rgba(255,255,255,1))] dark:bg-[linear-gradient(180deg,rgba(13,17,23,1),rgba(22,27,34,0.96))]"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_420px] lg:items-center">
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary-50 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 text-xs font-medium mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
          Backend Engineer · AI Native Workflow
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-4">
          <span class="gradient-text">{profile.name}</span>
        </h1>

        <p class="text-xl sm:text-2xl font-semibold text-surface-600 dark:text-surface-300 mb-3">
          {profile.title}
        </p>

        <p class="text-base sm:text-lg text-surface-500 dark:text-surface-400 mb-8 max-w-2xl leading-relaxed">
          {profile.bio}
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href="/projects"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-primary-600 hover:bg-primary-700 text-white font-medium transition-colors shadow-lg shadow-primary-600/25"
          >
            探索项目
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href={profile.contact.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-surface-300 dark:border-surface-600 text-surface-700 dark:text-surface-200 hover:bg-surface-50 dark:hover:bg-surface-800 font-medium transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>

      <div class="rounded-lg border border-surface-200 bg-surface-950 text-surface-100 shadow-2xl shadow-surface-900/20 dark:border-surface-700">
        <div class="flex items-center justify-between border-b border-surface-800 px-4 py-3">
          <div class="flex items-center gap-2">
            <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-yellow-400"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-green-400"></span>
          </div>
          <span class="text-xs text-surface-400">engineering-console</span>
        </div>
        <div class="space-y-5 p-5 font-mono text-sm">
          <div>
            <div class="mb-2 text-surface-500">$ focus</div>
            <div class="grid gap-2">
              <div class="rounded border border-surface-800 bg-surface-900/70 p-3">
                <div class="text-primary-300">platform_backend</div>
                <div class="mt-1 text-xs leading-relaxed text-surface-400">batch execution / rule validation / TLOG query / observability</div>
              </div>
              <div class="rounded border border-surface-800 bg-surface-900/70 p-3">
                <div class="text-accent-400">ai_engineering_loop</div>
                <div class="mt-1 text-xs leading-relaxed text-surface-400">context -> plan -> act -> verify -> reuse</div>
              </div>
            </div>
          </div>

          <div>
            <div class="mb-2 text-surface-500">$ proof</div>
            <div class="space-y-2 text-xs text-surface-300">
              <div class="flex items-center justify-between gap-3">
                <span>Engineering Playbook</span>
                <span class="rounded bg-green-500/15 px-2 py-0.5 text-green-300">reusable rules</span>
              </div>
              <div class="flex items-center justify-between gap-3">
                <span>GitHub Sentinel / InfoHunter</span>
                <span class="rounded bg-blue-500/15 px-2 py-0.5 text-blue-300">running systems</span>
              </div>
              <div class="flex items-center justify-between gap-3">
                <span>AI Auto Publisher</span>
                <span class="rounded bg-orange-500/15 px-2 py-0.5 text-orange-300">execution layer</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
