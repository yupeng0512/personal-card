---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogToc from '../../components/BlogToc.astro';
import { renderNoteMarkdown } from '../../lib/markdown';
import {
  formatNoteDate,
  getAllNotes,
  getCategoryLabel,
  getNoteSourceUrl,
  getNoteUrl,
  getRenderableNoteContent,
  getSubcategoryLabel,
  type Note,
} from '../../lib/notes';

type MarkdownHeading = {
  depth: number;
  slug: string;
  text: string;
};

export function getStaticPaths() {
  return getAllNotes().map(note => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props as { note: Note };
const allNotes = getAllNotes();
const noteIndex = allNotes.findIndex(item => item.slug === note.slug);
const newerNote = noteIndex > 0 ? allNotes[noteIndex - 1] : null;
const olderNote = noteIndex >= 0 ? allNotes[noteIndex + 1] : null;

const markdown = getRenderableNoteContent(note);
const rendered = markdown ? await renderNoteMarkdown(note, markdown) : null;
const headings = ((rendered?.metadata?.headings || []) as MarkdownHeading[])
  .filter(heading => heading.depth >= 2 && heading.depth <= 3);
---

<BaseLayout title={`${note.title} - Archer Yu`} description={note.summary || note.title}>
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[minmax(0,48rem)_16rem] xl:grid-cols-[minmax(0,48rem)_18rem]">
    <article class="min-w-0 max-w-3xl">
      <a href="/blog" class="mb-8 -ml-2 inline-flex min-h-11 items-center gap-1 rounded-lg px-2 text-sm text-surface-500 transition-colors hover:bg-surface-50 hover:text-primary-600 dark:text-surface-400 dark:hover:bg-surface-900 dark:hover:text-primary-400">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        返回笔记列表
      </a>

      <header class="mb-8">
        <div class="mb-4 flex flex-wrap items-center gap-2 text-sm text-surface-500 dark:text-surface-400">
          <time>{note.date}</time>
          <span class="text-surface-300 dark:text-surface-600">/</span>
          <span>{getCategoryLabel(note.category)}</span>
          {note.subcategory && (
            <>
              <span class="text-surface-300 dark:text-surface-600">/</span>
              <span>{getSubcategoryLabel(note.subcategory)}</span>
            </>
          )}
        </div>
        <h1 class="text-3xl font-bold leading-tight text-surface-900 dark:text-white sm:text-4xl">
          {note.title}
        </h1>
        {note.summary && (
          <p class="mt-5 text-lg leading-relaxed text-surface-500 dark:text-surface-400">
            {note.summary}
          </p>
        )}
        <div class="mt-5 flex flex-wrap gap-2">
          {note.tags.slice(0, 8).map(tag => (
            <span class="rounded-full bg-surface-100 px-3 py-1 text-xs font-medium text-surface-500 dark:bg-surface-800 dark:text-surface-400">
              {tag}
            </span>
          ))}
        </div>
      </header>

      {headings.length > 0 && (
        <details class="mb-8 rounded-lg border border-surface-200 bg-surface-50/70 p-4 dark:border-surface-700 dark:bg-surface-900/70 lg:hidden">
          <summary class="flex min-h-11 cursor-pointer items-center text-sm font-semibold text-surface-700 dark:text-surface-200">
            目录
          </summary>
          <div class="mt-4">
            <BlogToc headings={headings} labelledBy="blog-toc-mobile-title" hideTitle />
          </div>
        </details>
      )}

      {rendered ? (
        <div
          class="markdown-content prose prose-slate max-w-none dark:prose-invert prose-headings:scroll-mt-24 prose-a:font-medium prose-a:text-primary-600 prose-a:underline prose-a:underline-offset-2 dark:prose-a:text-primary-400"
          set:html={rendered.code}
        />
      ) : (
        <div class="rounded-lg border border-surface-200 bg-surface-50 p-5 text-sm text-surface-500 dark:border-surface-700 dark:bg-surface-900 dark:text-surface-400">
          这篇笔记还没有同步正文。运行 <code>npm run sync:notes</code> 后会生成完整内容。
        </div>
      )}

      <footer class="mt-12 border-t border-surface-200 pt-6 dark:border-surface-800">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <a
            href={getNoteSourceUrl(note)}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-11 items-center rounded-lg px-2 text-sm font-medium text-primary-600 hover:bg-primary-50 hover:text-primary-700 dark:text-primary-400 dark:hover:bg-surface-900"
          >
            查看 Markdown 源文件
          </a>
          <div class="text-sm text-surface-400 dark:text-surface-500">
            {formatNoteDate(note.date)}
          </div>
        </div>

        <nav class="mt-8 grid gap-3 sm:grid-cols-2">
          {olderNote && (
            <a href={getNoteUrl(olderNote)} class="rounded-lg border border-surface-200 p-4 transition-colors hover:border-primary-300 hover:bg-surface-50 dark:border-surface-700 dark:hover:border-primary-700 dark:hover:bg-surface-900">
              <div class="mb-1 text-xs text-surface-400 dark:text-surface-500">上一篇</div>
              <div class="line-clamp-2 text-sm font-medium text-surface-700 dark:text-surface-200">{olderNote.title}</div>
            </a>
          )}
          {newerNote && (
            <a href={getNoteUrl(newerNote)} class="rounded-lg border border-surface-200 p-4 text-left transition-colors hover:border-primary-300 hover:bg-surface-50 dark:border-surface-700 dark:hover:border-primary-700 dark:hover:bg-surface-900 sm:text-right">
              <div class="mb-1 text-xs text-surface-400 dark:text-surface-500">下一篇</div>
              <div class="line-clamp-2 text-sm font-medium text-surface-700 dark:text-surface-200">{newerNote.title}</div>
            </a>
          )}
        </nav>
      </footer>
    </article>

    {headings.length > 0 && (
      <aside class="hidden min-w-0 lg:block">
        <div class="sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto pr-2">
          <BlogToc headings={headings} />
        </div>
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .markdown-content :global(:is(h2, h3, h4):target) {
    color: rgb(76 110 245);
  }

  :global(.dark) .markdown-content :global(:is(h2, h3, h4):target) {
    color: rgb(145 167 255);
  }

  .markdown-content :global(pre) {
    overflow-x: auto;
  }

  .markdown-content :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .markdown-content :global(:not(pre) > code),
  .markdown-content :global(a) {
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .markdown-content :global(table) {
    display: block;
    width: 100%;
    overflow-x: auto;
  }

  .markdown-content :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin-inline: auto;
    border-radius: 0.5rem;
  }

  .markdown-content :global(p > img:only-child) {
    margin-block: 1.5rem;
  }
</style>
